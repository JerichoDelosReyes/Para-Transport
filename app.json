{
  "expo": {
    "name": "Para",
    "slug": "para-transport-test",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "para",
    "icon": "./assets/logo/appicon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo/splashscreen.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8A020"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Para uses your location to find your current position and show routes to your destination.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSSpeechRecognitionUsageDescription": "Para needs access to speech recognition to let you search for routes using your voice.",
        "NSMicrophoneUsageDescription": "Para needs access to the microphone to convert your speech into text searches."
      },
      "bundleIdentifier": "com.para.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo/appicon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO"
      ],
      "package": "com.para.app"
    },
    "web": {
      "favicon": "./assets/logo/appicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "@maplibre/maplibre-react-native",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo/appicon.png",
          "color": "#E6F4FE",
          "mode": "development"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ],
      "expo-speech-recognition"
    ],
    "extra": {
      "eas": {
        "projectId": "34665852-31df-4ca2-b87a-510e5909f06c"
      }
    },
    "owner": "noxen-cv",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/34665852-31df-4ca2-b87a-510e5909f06c"
    },
    "newArchEnabled": true
  }
}