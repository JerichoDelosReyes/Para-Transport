# Para Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection String
# Local: mongodb://localhost:27017/para
# Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/para
MONGODB_URI=mongodb://localhost:27017/para

# Server Port (optional)
PORT=3001

# Firebase Admin SDK Service Account (for production)
# Paste the ENTIRE contents of your serviceAccountKey.json as a single line
# Example: FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project",...}
# For local dev, you can instead place serviceAccountKey.json in backend/config/
FIREBASE_SERVICE_ACCOUNT=
